---
import { getGameConfig } from '@/lib/data';
const config = getGameConfig();
const year = new Date().getFullYear();
---
<footer class="border-t border-gray-200 dark:border-gray-800 mt-16 py-8">
  <div class="max-w-6xl mx-auto px-4 text-center text-sm text-gray-500">
    <div class="flex justify-center gap-4 mb-3">
      <a href="/about/" class="hover:text-orange-500 transition-colors">About</a>
      <a href="/privacy-policy/" class="hover:text-orange-500 transition-colors">Privacy Policy</a>
      <a href="/terms/" class="hover:text-orange-500 transition-colors">Terms</a>
      <a href="/contact/" class="hover:text-orange-500 transition-colors">Contact</a>
    </div>
    <p class="mb-2">🔥 {config.game.name} Guide & Tools — Fan-made companion site. Not affiliated with Roblox Corporation or the {config.game.name} developers.</p>
    <p>&copy; {year} All rights reserved.</p>
  </div>
</footer>
