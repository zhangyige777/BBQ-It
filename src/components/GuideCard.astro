---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}
const { title, description, href, icon = '📄' } = Astro.props;
---
<a href={href} class="block p-5 border border-gray-200 dark:border-gray-800 rounded-xl hover:border-orange-400 dark:hover:border-orange-600 hover:shadow-lg transition-all group bg-white dark:bg-gray-900">
  <div class="text-2xl mb-2">{icon}</div>
  <h3 class="font-semibold group-hover:text-orange-500 transition-colors mb-1">{title}</h3>
  <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{description}</p>
</a>
