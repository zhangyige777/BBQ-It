---
interface Props {
  links: { title: string; url: string; description: string }[];
}
const { links } = Astro.props;
---
<section>
  <h2 class="text-2xl font-bold mb-6">Related Guides</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {links.map(link => (
      <a href={link.url} class="block p-4 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 dark:hover:border-orange-600 hover:shadow-md transition-all group">
        <h3 class="font-semibold group-hover:text-orange-500 transition-colors mb-1">{link.title}</h3>
        <p class="text-sm text-gray-500 dark:text-gray-400">{link.description}</p>
      </a>
    ))}
  </div>
</section>
