---
interface Props {
  rows: { label: string; value: string }[];
  caption?: string;
}
const { rows, caption } = Astro.props;
---
<div class="mb-8 overflow-x-auto">
  {caption && <p class="text-sm text-gray-500 dark:text-gray-400 mb-2 font-medium">{caption}</p>}
  <table class="w-full text-sm border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden">
    <tbody>
      {rows.map(row => (
        <tr class="border-b border-gray-100 dark:border-gray-800 last:border-b-0">
          <td class="px-4 py-2 font-medium text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-900 w-1/3">{row.label}</td>
          <td class="px-4 py-2 text-gray-900 dark:text-gray-100">{row.value}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
