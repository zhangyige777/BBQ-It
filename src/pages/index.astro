---
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/JsonLd.astro';
import FAQItem from '@/components/FAQItem.astro';
import GuideCard from '@/components/GuideCard.astro';
import AdSlot from '@/components/AdSlot.astro';
import { getGameConfig, getActiveCodes, generateVideoGameSchema, generateBreadcrumbSchema, generateFAQSchema } from '@/lib/data';

const config = getGameConfig();
const activeCodes = getActiveCodes().slice(0, 3);

const breadcrumbSchema = generateBreadcrumbSchema([{ name: 'Home', url: '/' }]);
const videoGameSchema = generateVideoGameSchema();

const faqItems = [
  { question: 'What is BBQ It on Roblox?', answer: 'BBQ It is a cooking tycoon game on Roblox where you grill meats, serve customers, upgrade your equipment, and build a BBQ empire. You can cook offline, collect rare meats, and optimize your profits with upgrades and totems.' },
  { question: 'How do I get codes for BBQ It?', answer: 'New codes are released on the official BBQ It Discord server and through developer social media. We track all working codes on our Codes page — check back regularly for updates.' },
  { question: 'What is the best meat in BBQ It?', answer: 'The best meat depends on your progression stage. Dragon Ribs (S-tier) has the highest profit, but it requires late-game equipment. For mid-game, Ribeye and Salmon offer excellent returns. See our Meat Tier List for full rankings.' },
  { question: 'How does perfect cooking work?', answer: 'Perfect cooking requires timing your meat removal at exactly the right moment. Each meat has a specific cook window. Perfect cooks sell for significantly more than normal cooks. Check our Perfect Cook Guide for detailed timing tips.' },
  { question: 'Can I earn money offline in BBQ It?', answer: 'Yes! Once you unlock Offline Grills, your meats continue cooking while you are away. Offline earnings depend on your grill setup, meat type, and how long you are away. Use our Offline Profit Calculator to estimate your earnings.' },
  { question: 'What should I buy first in BBQ It?', answer: 'Prioritize upgrading your grill capacity first, then get a better table to serve more customers. After that, invest in Offline Grills for passive income. See our What to Buy First guide for a detailed priority list.' },
];

const faqSchema = generateFAQSchema(faqItems);
---
<BaseLayout>
  <JsonLd schema={[breadcrumbSchema, videoGameSchema, faqSchema]} />

  <!-- Hero -->
  <section class="max-w-4xl mx-auto px-4 py-16 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">BBQ It Guide, Codes, Wiki & Calculators</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-8 max-w-2xl mx-auto">Cook better meat, make money faster, and plan your upgrades in Roblox BBQ It.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/calculator/meat-profit/" class="px-6 py-3 bg-orange-500 hover:bg-orange-600 text-white font-bold rounded-lg transition-colors">Use Profit Calculator</a>
      <a href="/beginner-guide/" class="px-6 py-3 border border-orange-500 text-orange-500 hover:bg-orange-50 dark:hover:bg-orange-950 font-bold rounded-lg transition-colors">Read Beginner Guide</a>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold mb-6 text-center">Quick Links</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      <GuideCard title="Codes" description="All working codes" href="/codes/" icon="🎟️" />
      <GuideCard title="Perfect Cook" description="Master the timing" href="/perfect-cook/" icon="🎯" />
      <GuideCard title="Meat Tier List" description="Best meats ranked" href="/meat-tier-list/" icon="🥩" />
      <GuideCard title="Offline Grills" description="Earn while away" href="/offline-grills/" icon="😴" />
      <GuideCard title="Best Upgrades" description="Spend wisely" href="/upgrades/" icon="⬆️" />
      <GuideCard title="Profit Calculator" description="Calculate earnings" href="/calculator/meat-profit/" icon="🧮" />
    </div>
  </section>

  <!-- Latest Codes -->
  {activeCodes.length > 0 && (
    <section class="max-w-4xl mx-auto px-4 pb-12">
      <h2 class="text-2xl font-bold mb-6">Latest Codes</h2>
      <div class="space-y-3">
        {activeCodes.map(code => (
          <div class="flex items-center justify-between p-4 border border-gray-200 dark:border-gray-800 rounded-lg bg-white dark:bg-gray-900">
            <div>
              <span class="font-mono font-bold text-orange-500">{code.code}</span>
              <span class="text-sm text-gray-500 ml-3">{code.reward}</span>
              {code.isNew && <span class="ml-2 px-2 py-0.5 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs font-bold rounded">NEW</span>}
            </div>
          </div>
        ))}
      </div>
      <a href="/codes/" class="inline-block mt-4 text-orange-500 hover:text-orange-600 font-medium">View all codes →</a>
    </section>
  )}

  <!-- Calculators -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold mb-6 text-center">Calculators & Tools</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <GuideCard title="Meat Profit Calculator" description="Calculate profit per meat and find the best meat to cook." href="/calculator/meat-profit/" icon="💰" />
      <GuideCard title="Offline Profit Calculator" description="Estimate your earnings while away from the game." href="/calculator/offline-profit/" icon="😴" />
      <GuideCard title="Upgrade ROI Calculator" description="Find the best upgrade to buy next." href="/calculator/upgrade-roi/" icon="📈" />
      <GuideCard title="Grill Layout Planner" description="Plan the optimal grill setup for your stage." href="/calculator/grill-layout/" icon="🏗️" />
      <GuideCard title="Meat Weight Calculator" description="Calculate sell value based on meat weight." href="/calculator/meat-weight/" icon="⚖️" />
    </div>
  </section>

  <!-- In-feed ad -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <AdSlot id="home-feed" />
  </section>

  <!-- Beginner Path -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold mb-6 text-center">Getting Started</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="text-center p-6 border border-gray-200 dark:border-gray-800 rounded-xl">
        <div class="text-3xl mb-3">📖</div>
        <h3 class="font-bold mb-2">1. Learn the Basics</h3>
        <p class="text-sm text-gray-500">Understand cooking, serving, and the core mechanics.</p>
        <a href="/beginner-guide/" class="text-orange-500 text-sm font-medium mt-2 inline-block">Beginner Guide →</a>
      </div>
      <div class="text-center p-6 border border-gray-200 dark:border-gray-800 rounded-xl">
        <div class="text-3xl mb-3">🔥</div>
        <h3 class="font-bold mb-2">2. Set Up Grills</h3>
        <p class="text-sm text-gray-500">Buy the right grills and arrange them for max efficiency.</p>
        <a href="/grills/" class="text-orange-500 text-sm font-medium mt-2 inline-block">Grills Guide →</a>
      </div>
      <div class="text-center p-6 border border-gray-200 dark:border-gray-800 rounded-xl">
        <div class="text-3xl mb-3">💰</div>
        <h3 class="font-bold mb-2">3. Optimize Profits</h3>
        <p class="text-sm text-gray-500">Use calculators and strategies to maximize your earnings.</p>
        <a href="/money-guide/" class="text-orange-500 text-sm font-medium mt-2 inline-block">Money Guide →</a>
      </div>
    </div>
  </section>

  <!-- Money & Meat & Equipment Guides -->
  <section class="max-w-6xl mx-auto px-4 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Money Guides -->
      <div>
        <h2 class="text-xl font-bold mb-4">💰 Money Guides</h2>
        <div class="space-y-3">
          <a href="/money-guide/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Money Guide</span>
            <p class="text-xs text-gray-500">How to make money fast</p>
          </a>
          <a href="/profit-strategy/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Profit Strategy</span>
            <p class="text-xs text-gray-500">Advanced profit tips</p>
          </a>
          <a href="/what-to-buy-first/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">What to Buy First</span>
            <p class="text-xs text-gray-500">Best early purchases</p>
          </a>
        </div>
      </div>
      <!-- Meat Guides -->
      <div>
        <h2 class="text-xl font-bold mb-4">🥩 Meat Guides</h2>
        <div class="space-y-3">
          <a href="/meat-tier-list/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Meat Tier List</span>
            <p class="text-xs text-gray-500">All meats ranked</p>
          </a>
          <a href="/perfect-cook/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Perfect Cook Guide</span>
            <p class="text-xs text-gray-500">Master the timing</p>
          </a>
          <a href="/meat-values/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Meat Values</span>
            <p class="text-xs text-gray-500">Complete value table</p>
          </a>
        </div>
      </div>
      <!-- Equipment Guides -->
      <div>
        <h2 class="text-xl font-bold mb-4">🔧 Equipment</h2>
        <div class="space-y-3">
          <a href="/grills/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Grills Guide</span>
            <p class="text-xs text-gray-500">All grills compared</p>
          </a>
          <a href="/offline-grills/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Offline Grills</span>
            <p class="text-xs text-gray-500">Earn while away</p>
          </a>
          <a href="/upgrades/" class="block p-3 border border-gray-200 dark:border-gray-800 rounded-lg hover:border-orange-400 transition-colors">
            <span class="font-medium">Upgrades Guide</span>
            <p class="text-xs text-gray-500">Best upgrades ranked</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Game Stats -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-2xl font-bold mb-6 text-center">BBQ It Stats</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <div class="text-center p-4 bg-gray-50 dark:bg-gray-900 rounded-lg">
        <div class="text-2xl font-bold text-orange-500">{config.stats.visits}</div>
        <div class="text-sm text-gray-500">Visits</div>
      </div>
      <div class="text-center p-4 bg-gray-50 dark:bg-gray-900 rounded-lg">
        <div class="text-2xl font-bold text-orange-500">{config.stats.favorites}</div>
        <div class="text-sm text-gray-500">Favorites</div>
      </div>
      <div class="text-center p-4 bg-gray-50 dark:bg-gray-900 rounded-lg">
        <div class="text-2xl font-bold text-orange-500">{config.stats.likes}</div>
        <div class="text-sm text-gray-500">Likes</div>
      </div>
      <div class="text-center p-4 bg-gray-50 dark:bg-gray-900 rounded-lg">
        <div class="text-2xl font-bold text-orange-500">{config.stats.serverSize}</div>
        <div class="text-sm text-gray-500">Server Size</div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-4xl mx-auto px-4 pb-16">
    <h2 class="text-2xl font-bold mb-6 text-center">Frequently Asked Questions</h2>
    <div class="space-y-3">
      {faqItems.map(item => <FAQItem question={item.question} answer={item.answer} />)}
    </div>
    <div class="text-center mt-6">
      <a href="/faq/" class="text-orange-500 hover:text-orange-600 font-medium">View all FAQ →</a>
    </div>
  </section>
</BaseLayout>
