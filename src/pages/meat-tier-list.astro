---
import BaseLayout from '@/layouts/BaseLayout.astro';
import JsonLd from '@/components/JsonLd.astro';
import DataDisclaimer from '@/components/DataDisclaimer.astro';
import RelatedGuides from '@/components/RelatedGuides.astro';
import { getMeats, getMeatsByTier, generateBreadcrumbSchema, generateItemListSchema } from '@/lib/data';

const meats = getMeats();
const sortedMeats = [...meats].sort((a, b) => {
  const tierOrder: Record<string, number> = { S: 0, A: 1, B: 2, C: 3, D: 4 };
  return tierOrder[a.tier] - tierOrder[b.tier];
});
const tiers = ['S', 'A', 'B', 'C', 'D'];
const tierColors: Record<string, string> = {
  S: 'bg-yellow-100 dark:bg-yellow-900 border-yellow-300 dark:border-yellow-700',
  A: 'bg-purple-100 dark:bg-purple-900 border-purple-300 dark:border-purple-700',
  B: 'bg-blue-100 dark:bg-blue-900 border-blue-300 dark:border-blue-700',
  C: 'bg-green-100 dark:bg-green-900 border-green-300 dark:border-green-700',
  D: 'bg-gray-100 dark:bg-gray-800 border-gray-300 dark:border-gray-700',
};
const tierTextColors: Record<string, string> = {
  S: 'text-yellow-700 dark:text-yellow-300',
  A: 'text-purple-700 dark:text-purple-300',
  B: 'text-blue-700 dark:text-blue-300',
  C: 'text-green-700 dark:text-green-300',
  D: 'text-gray-600 dark:text-gray-400',
};
const tierDescriptions: Record<string, string> = {
  S: 'Endgame — Best-in-class meats for maximum profit.',
  A: 'Premium — Excellent profit with good equipment.',
  B: 'Solid — Good mid-to-late game options.',
  C: 'Decent — Useful for early-to-mid progression.',
  D: 'Starter — Good for learning, replace ASAP.',
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Meat Tier List', url: '/meat-tier-list/' },
]);
const itemListSchema = generateItemListSchema(
  meats.map((m, i) => ({ name: m.name, url: `/meats/${m.slug}/`, position: i + 1 }))
);
---
<BaseLayout title="BBQ It Meat Tier List — All Meats Ranked (June 2026)" description="Complete BBQ It meat tier list ranking all meats from S to D tier. Compare profit, cook time, and value for every meat type.">
  <JsonLd schema={[breadcrumbSchema, itemListSchema]} />

  <article class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl md:text-4xl font-bold mb-4">BBQ It Meat Tier List</h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 mb-6">All meats ranked from best to worst based on profit potential, cook efficiency, and progression value.</p>

    <DataDisclaimer />

    <!-- Quick Comparison Table -->
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden">
        <thead class="bg-gray-50 dark:bg-gray-900">
          <tr>
            <th class="px-4 py-2 text-left font-bold">Tier</th>
            <th class="px-4 py-2 text-left font-bold">Meat</th>
            <th class="px-4 py-2 text-left font-bold">Raw Cost</th>
            <th class="px-4 py-2 text-left font-bold">Perfect Value</th>
            <th class="px-4 py-2 text-left font-bold">Profit</th>
            <th class="px-4 py-2 text-left font-bold">Cook Time</th>
          </tr>
        </thead>
        <tbody>
          {sortedMeats.map(meat => (
            <tr class="border-t border-gray-100 dark:border-gray-800">
              <td class="px-4 py-2">
                <span class={`px-2 py-0.5 rounded text-xs font-bold ${tierColors[meat.tier]} ${tierTextColors[meat.tier]}`}>{meat.tier}</span>
              </td>
              <td class="px-4 py-2 font-medium">
                <a href={`/meats/${meat.slug}/`} class="hover:text-orange-500 transition-colors">{meat.name}</a>
              </td>
              <td class="px-4 py-2">{meat.rawCost}</td>
              <td class="px-4 py-2 text-green-600 dark:text-green-400 font-bold">{meat.perfectValue}</td>
              <td class="px-4 py-2 text-orange-500 font-bold">+{meat.perfectValue - meat.rawCost}</td>
              <td class="px-4 py-2">{meat.cookTime}s</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Tier Breakdowns -->
    {tiers.map(tier => {
      const tierMeats = getMeatsByTier(tier);
      if (tierMeats.length === 0) return null;
      return (
        <section class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class={`px-3 py-1 rounded-lg text-lg font-bold ${tierColors[tier]} ${tierTextColors[tier]}`}>{tier} Tier</span>
            <span class="text-sm text-gray-500">{tierDescriptions[tier]}</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {tierMeats.map(meat => (
              <div class={`p-4 border-2 rounded-lg ${tierColors[tier]}`}>
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-bold text-lg">{meat.name}</h3>
                  <a href={`/meats/${meat.slug}/`} class="text-sm text-orange-500 hover:underline">Full Guide →</a>
                </div>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">{meat.description}</p>
                <div class="grid grid-cols-3 gap-2 text-xs">
                  <div class="text-center p-2 bg-white/50 dark:bg-black/20 rounded">
                    <div class="font-bold">Cost</div>
                    <div>{meat.rawCost}</div>
                  </div>
                  <div class="text-center p-2 bg-white/50 dark:bg-black/20 rounded">
                    <div class="font-bold">Perfect</div>
                    <div class="text-green-600">{meat.perfectValue}</div>
                  </div>
                  <div class="text-center p-2 bg-white/50 dark:bg-black/20 rounded">
                    <div class="font-bold">Time</div>
                    <div>{meat.cookTime}s</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}

    <RelatedGuides links={[
      { title: 'Best Meat Guide', url: '/best-meat/', description: 'Best meat for each game stage.' },
      { title: 'Meat Values', url: '/meat-values/', description: 'Complete value table for all meats.' },
      { title: 'Perfect Cook Guide', url: '/perfect-cook/', description: 'How to get perfect cooks.' },
      { title: 'Meat Profit Calculator', url: '/calculator/meat-profit/', description: 'Calculate your meat profits.' },
    ]} />
  </article>
</BaseLayout>
